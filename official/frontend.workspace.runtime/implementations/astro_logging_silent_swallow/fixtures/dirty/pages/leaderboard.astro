---
// Dirty: the frontmatter catch returns a fallback with no log and no rethrow — the
// fetch failure silently becomes an empty leaderboard.
interface Row {
  player: string;
  score: number;
}

async function loadRows(): Promise<Row[]> {
  try {
    const res = await fetch(`${import.meta.env.API_URL}/leaderboard`);
    return await res.json();
  } catch (e) {
    // ❌ swallow: no log, no rethrow — just a silent empty list.
    return [];
  }
}

const rows = await loadRows();
---

<ul>
  {rows.map((r) => <li>{r.player}: {r.score}</li>)}
</ul>
