---
// CLEAN: every credential is read from the environment, never inlined.
const apiKey = import.meta.env.PUBLIC_API_KEY;
const dbToken = import.meta.env.DB_ACCESS_TOKEN;
const clientSecret = import.meta.env.OAUTH_CLIENT_SECRET;
const title = "Forge 100";
---

<section>
  <h1>{title}</h1>
  <p data-has-key={Boolean(apiKey)}>configured</p>
  <p>{dbToken ? "db ready" : "no db"}</p>
  <p>{clientSecret ? "oauth ready" : "no oauth"}</p>
</section>
